{
  "contract": "SCHOL-PARADIGM-v1",
  "id": "bug-diagnose",
  "version": "0.1.0",
  "priority": 10,
  "match": {
    "patterns": [
      "(error|bug|crash|fail|broken|exception|traceback|stack trace)",
      "(fix|resolve|diagnose|debug|troubleshoot)",
      "(Internal Server Error|OOM|SIGTERM|SIGKILL|segfault|TypeError|ImportError)"
    ],
    "keywords": [
      "error",
      "bug",
      "crash",
      "fail",
      "broken",
      "exception",
      "fix",
      "diagnose",
      "debug",
      "traceback",
      "stack",
      "Internal Server Error",
      "SIGTERM",
      "OOM",
      "segfault"
    ],
    "bytecode_prefixes": [
      "PB-ERR",
      "SCHOL-ERR",
      "PB-OK"
    ]
  },
  "steps": [
    {
      "source": "substrate",
      "query": "bug fix for {query}",
      "label": "Bug memory",
      "top_k": 8,
      "max_results": 5,
      "retrieve_as": "bug_history"
    },
    {
      "source": "cleri",
      "query": "{query}",
      "label": "RAID pattern match",
      "max_results": 5,
      "retrieve_as": "raid_hits"
    },
    {
      "source": "file-system",
      "query": "{query}",
      "paths": [
        "codex/",
        "src/"
      ],
      "label": "Affected source files",
      "max_results": 10,
      "retrieve_as": "source_files"
    },
    {
      "source": "immune-scan",
      "query": "{query}",
      "label": "Immunity violations",
      "retrieve_as": "immunity"
    }
  ],
  "system_suffix": "CHAIN: identify the error \u2192 trace to source file \u2192 check Cleri RAID for known patterns \u2192 propose fix with code. Include bytecode error code if applicable. Self-critique: does the fix introduce new side effects?",
  "checksum": "e0d49851"
}
