# DivTube_downloader environment — copy to .env and fill in your own keys.
# .env is gitignored; never commit real keys.

# Google YouTube Data API v3 key (required for /analyze, /download, Intel)
YOUTUBE_API_KEY=

# Google Gemini API key (test_key.py, list_models.py, Gemini critique)
GEMINI_API_KEY=

# OpenCode / xAI (Grok) keys for the Content Critic LLM pipeline
OPENCODE_API_KEY=
GROK_API_KEY=

# Active LLM provider used by /critique and /scholomance.
# Set ONE base/models pair. Examples:
#   xAI:      https://api.x.ai/v1
#   OpenCode: https://opencode.ai/zen/v1
CUSTOM_API_KEY=
CUSTOM_API_BASE=https://opencode.ai/zen/v1
CUSTOM_MODELS_URL=https://opencode.ai/zen/v1
