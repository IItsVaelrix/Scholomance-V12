/* ════════════════════════════════════════════════════════════════════════
   DivTube Cockpit — Disciplined Grimoire
   Every colour here is a $token resolved from tui/ui/theme.py via
   DivTubeAgentApp.get_css_variables(). No raw hex lives in this file — the
   palette is changed in ONE place (theme.py), never scattered here.

   The discipline: panels REST in a uniform muted $panel-border. Exactly one
   surface wears $accent-primary at a time — the active conversation and the
   widget you're focused in — so the eye always knows where it is. Border
   colour encodes state (focus), not decoration.
   ════════════════════════════════════════════════════════════════════════ */

Screen {
    background: $background;
}

/* ── window chrome ─────────────────────────────────────────────────────── */
Header {
    background: $surface;
    color: $text-bright;
    text-style: bold;
    padding: 0 1;
}
HeaderTitle {
    color: $accent-tertiary;
    text-style: bold;
}
Footer {
    background: $surface;
}
FooterKey {
    background: $surface;
    color: $text-secondary;
    transition: background 200ms, color 200ms;
}
FooterKey > .footer-key--key {
    color: $background;
    background: $accent-tertiary;
    text-style: bold;
}
FooterKey > .footer-key--description {
    color: $text-secondary;
}
FooterKey:hover {
    background: $panel-border;
    color: $text-bright;
}

/* ── resting panels: ONE uniform muted boundary, no per-panel colour ────── */
#sidebar, #aether-meter, #inspector, #radar, #code-viewer {
    background: $surface;
    border: round $panel-border;
    border-title-color: $text-secondary;
    border-title-align: center;
}
/* per-panel geometry only — colour is inherited from the rule above */
#sidebar      { width: 32;    padding: 1 1; margin: 1 0 1 1; }
#aether-meter { height: 6;    padding: 0 1; margin: 1 1 0 0; }
#inspector    { height: 1fr;  padding: 1 1; margin: 1 1 1 0; }
#radar        { height: 1fr;  padding: 1 1; margin: 0 1 1 0;
                background: $background; text-align: center;
                content-align: center middle; }
#code-viewer  { height: 1fr;  padding: 0 1; margin: 1 1 1 0; }

#right-panel  { width: 42; background: $background; }
#center-panel { width: 1fr; background: $background; padding: 1 1; }

/* ── PRIMARY surface: the active conversation wears the accent ──────────── */
.chat-log-cls {
    background: $surface;
    color: $text-bright;
    border: round $accent-primary;
    border-title-color: $text-bright;
    border-title-align: center;
    padding: 0 1;
    scrollbar-color: $accent-secondary;
    scrollbar-color-hover: $accent-tertiary;
    scrollbar-color-active: $accent-tertiary;
    scrollbar-background: $background;
    scrollbar-size-vertical: 1;
}

/* the typewriter is the agent's live voice → rests muted, glows when speaking */
#typewriter-box {
    background: $surface;
    color: $text-bright;
    height: auto;
    min-height: 3;
    max-height: 30;
    border: round $panel-border;
    border-title-color: $text-secondary;
    border-title-align: center;
    padding: 0 1;
    overflow-y: scroll;
    display: none;
    margin-top: 1;
}
#typewriter-box.-active {
    display: block;
    border: round $accent-primary;
    border-title-color: $text-bright;
}

/* ── sidebar: identity kept as TEXT colour, never a second border ───────── */
.sidebar-heading {
    margin-top: 1;
    margin-bottom: 0;
    text-style: bold;
    color: $accent-secondary;
    padding-left: 1;
}
.sidebar-button {
    width: 100%;
    min-width: 0;            /* kill Button's default min-width that centres labels */
    height: 1;
    border: none;
    background: transparent;
    color: $text-secondary;
    text-align: left;        /* commands read as a left-aligned list under the heading */
    content-align: left middle;
    padding: 0 0 0 3;        /* indent under the flush heading → visual tree */
    transition: background 200ms, color 200ms;
}
.sidebar-button:hover {
    background: $panel-border;
    color: $accent-tertiary;
    text-style: bold;
}

/* ── command input: rests muted, glows accent on focus (state-driven) ───── */
#command-input {
    dock: bottom;
    width: 100%;
    height: 3;
    margin: 1;
    background: $surface;
    border: round $panel-border;
}
#command-input.expanded {
    height: 15;
}
#command-input:focus {
    border: round $accent-primary;
}

.cmd-list { padding: 1 0 0 1; }
.muted { color: $muted; }
.glyph-container {
    dock: bottom;
    content-align: center middle;
    padding-bottom: 1;
    height: 9;
    color: $accent-secondary;
}

#loading-bar { display: none; height: 1; margin: 1 0; }
#loading-bar.working  > Bar > .bar--bar { color: $error; }
#loading-bar.finished > Bar > .bar--bar { color: $success; }
#loading-bar.working  .bar--bar { color: $error; }
#loading-bar.finished .bar--bar { color: $success; }

/* ── model-select modal ────────────────────────────────────────────────── */
ModelSelectScreen {
    align: center middle;
    background: $background 92%;
}
#model-dialog {
    width: 60;
    height: 20;
    background: $surface;
    border: round $accent-secondary;
    border-title-color: $text-bright;
    padding: 0;
    box-sizing: border-box;
}
#model-title {
    background: $panel-border;
    color: $accent-tertiary;
    text-style: bold;
    content-align: center middle;
    width: 100%;
    padding: 1;
    border-bottom: solid $accent-secondary;
}
OptionList {
    background: transparent;
    border: none;
    padding: 1 1;
}
OptionList > .option-list--option-highlighted {
    background: $panel-border;
    color: $text-bright;
    text-style: bold;
}
