{
  "compilerOptions": {
    "target": "ES2022",
    "lib": [
      "ES2022",
      "DOM",
      "DOM.Iterable"
    ],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "strict": false,
    "noImplicitAny": false,
    "strictNullChecks": false,
    "allowJs": true,
    "checkJs": false,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "types": [
      "node"
    ],
    "typeRoots": [
      "./node_modules/@types"
    ]
  },
  "include": [
    "src/vite-env.d.ts",
    "src/pages/Read/ScrollEditor.jsx",
    "src/pages/Read/ReadPage.jsx",
    "src/pages/Read/ToolsSidebar.jsx",
    "src/pages/Read/SearchPanel.jsx"
  ],
  "exclude": [
    "codex/**",
    "node_modules"
  ]
}