{
  "$schema": "https://unpkg.com/knip@latest/schema.json",
  "entry": [
    "codex/core/diagnostic/index.js",
    "codex/core/phonology/dictionary.worker.js"
  ],
  "project": [
    "src/**/*.{js,jsx,ts,tsx}",
    "codex/**/*.{js,ts}"
  ],
  "ignore": [
    "src/types/**",
    ".tmp/**",
    "ARCHIVE REFERENCE DOCS/**"
  ],
  "ignoreDependencies": [
    "@fontsource/press-start-2p"
  ],
  "ignoreBinaries": [
    "python"
  ],
  "ignoreExportsUsedInFile": true
}
