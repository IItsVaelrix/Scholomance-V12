#!/bin/bash

# Change to the root project directory relative to this script
SCRIPT_DIR="$( cd "$( dirname "${BASH_SOURCE[0]}" )" && pwd )"
cd "$SCRIPT_DIR/.."

# Source the virtual environment
if [ -f "nlp_chatbot/venv/bin/activate" ]; then
    source nlp_chatbot/venv/bin/activate
else
    echo "Virtual environment not found. Please run: python -m venv nlp_chatbot/venv"
    exit 1
fi

export PYTHONPATH=.

# Launch the app
python -m nlp_chatbot.client.launcher "$@"
