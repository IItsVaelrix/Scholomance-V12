# Void1-armR-upper.scdl — right shoulder → elbow joint segment

asset Void1ArmRUpper canvas 32x48

palette {
  robehi    = #4E3880
  robemid   = #352560
  robeshade = #1B1230
  golddark  = #A8862F
  joint     = #0A0712
