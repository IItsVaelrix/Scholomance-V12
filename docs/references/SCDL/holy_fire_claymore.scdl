# -----------------------------------------------------------------------------
# HOLY FIRE CLAYMORE
# Design target: ceremonial fantasy sword, gold forged shell, red sanctified core,
# fire aura shaped like a cathedral flame. Structure uses symmetry; flame sparks
# and glints are hand placed so the sprite does not feel machine mirrored.
# -----------------------------------------------------------------------------

part rear_fire_shadow material shadow_fire {
  symmetry x
  polygon 31 83 25 83 23 75 19 68 22 72 17 62 20 65 15 52 18 56 14 42 19 46 17 32 21 36 19 22 24 26 25 12 28 16 31 0 emberdeep
  polygon 22 80 17 70 21 75 15 62 19 66 13 52 17 56 emberdeep
  polygon 20 50 15 38 19 42 13 28 17 32 emberdeep
  polygon 23 28 18 18 21 22 16 8 20 12 emberdeep
}

