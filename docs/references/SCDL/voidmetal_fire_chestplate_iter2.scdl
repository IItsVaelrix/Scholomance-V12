}

# Orange underglow under gem and cracks. Painted before metal cradle.
part fire_underpaint material shadow_fire {
  polygon 48 39 60 51 58 67 48 82 38 67 36 51 emberdeep
  polygon 48 45 55 56 53 66 48 75 43 66 41 56 orangehot
}

# Metal cradle with clearer diamond geometry.
part gem_cradle material silver {
  polygon 48 37 64 51 64 67 48 84 32 67 32 51 voidblack
  polygon 48 42 58 51 58 65 48 76 38 65 38 51 steeldeep
  line 48 37 64 51 silveredge
  line 64 51 64 67 steelhi
  line 64 67 48 84 silveredge
  line 48 84 32 67 steelhi
  line 32 67 32 51 silveredge
  line 32 51 48 37 silveredge
  line 38 51 58 51 steelhi
  line 38 65 58 65 steelhi
