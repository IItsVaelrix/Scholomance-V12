}

part central_gem material divine_flame_core {
  sphere 48 58 radius 8 light -1 -1 gemshine whitehot gemhot gemmid gemdark
  polygon 48 44 56 58 48 75 40 58 gemmid
  polygon 48 48 53 58 48 70 43 58 orangehot
  polygon 48 51 51 58 48 65 45 58 whitehot
  line 48 44 56 58 whitehot
  line 56 58 48 75 ember
  line 48 75 40 58 emberdeep
  line 40 58 48 44 goldhot
