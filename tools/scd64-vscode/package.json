{
  "name": "scd64-hover",
  "displayName": "SCD64 Diagnostic Hover",
  "description": "Hover over 64-character SCD64 signatures to decode them.",
  "version": "1.0.0",
  "publisher": "scholomance",
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": []
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "install:code": "npx -y @vscode/vsce package && code --install-extension scd64-hover-1.0.0.vsix --force"
  },
  "devDependencies": {
    "@types/node": "16.x",
    "@types/vscode": "^1.80.0",
    "typescript": "^5.1.3"
  },
  "dependencies": {
    "vscode-languageclient": "^10.0.0"
  }
}
